# Copy to .env and fill in. See README for field docs.
LLM_MODEL=anthropic:claude-opus-4-8
ANTHROPIC_API_KEY=
POSTGRES_DSN=
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_TOKEN=
DATAHUB_MCP_TRANSPORT=
DATAHUB_MCP_COMMAND=uvx mcp-server-datahub
DATAHUB_MCP_URL=
TOOLS_IS_MUTATION_ENABLED=false
TOOLS_IS_USER_ENABLED=false
DATA_QUALITY_TOOLS_ENABLED=false
SAVE_DOCUMENT_TOOL_ENABLED=true
DATAHUB_MCP_DOCUMENT_TOOLS_DISABLED=false
METRICGUARD_CONTRACTS_DIR=.metricguard/contracts
METRICGUARD_DIALECT=postgres
METRICGUARD_REQUIRE_APPROVAL=true
